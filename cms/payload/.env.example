# Payload CMS Environment Variables

# Database
MONGODB_URI=mongodb://localhost:27017/cah-cms
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/cah-cms

# Payload
PAYLOAD_SECRET=your-payload-secret-key-min-32-chars
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Frontend URL (for CORS and webhooks)
FRONTEND_URL=http://localhost:3000

# Sync Service
SYNC_SERVICE_URL=http://localhost:3002
PAYLOAD_WEBHOOK_SECRET=your-payload-webhook-secret

# Revalidation
REVALIDATE_SECRET=your-revalidate-secret-key

# Production URLs (for deployment)
# PAYLOAD_PUBLIC_SERVER_URL=https://your-payload-cms.vercel.app
# FRONTEND_URL=https://your-frontend.vercel.app
# SYNC_SERVICE_URL=https://your-sync-service.onrender.com
