# Medusa Backend Environment Variables

# Database
DATABASE_URL=postgres://localhost/medusa-store
# For production: postgres://username:password@host:5432/medusa-store

# Redis (for caching and jobs)
REDIS_URL=redis://localhost:6379

# Medusa
JWT_SECRET=your-jwt-secret-key
COOKIE_SECRET=your-cookie-secret-key
MEDUSA_ADMIN_ONBOARDING_TYPE=default

# Store Details
STORE_CORS=http://localhost:3000,http://localhost:7001
ADMIN_CORS=http://localhost:7001

# Sync Service
SYNC_SERVICE_URL=http://localhost:3002
MEDUSA_WEBHOOK_SECRET=your-medusa-webhook-secret

# API Key (for sync service)
MEDUSA_API_KEY=your-medusa-api-key

# Production URLs (for deployment)
# STORE_CORS=https://your-frontend.vercel.app
# ADMIN_CORS=https://your-medusa-admin.vercel.app
# SYNC_SERVICE_URL=https://your-sync-service.onrender.com
